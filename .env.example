# Vigilant environment configuration
# Copy this file to `.env` and fill in your values.

# App
APP_NAME=Vigilant
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database Mode: USE_SQLITE=true (no MySQL needed) | USE_SQLITE=false (MySQL)
USE_SQLITE=true
SQLITE_PATH=vigilant_dev.db

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=vigilant_user
DB_PASSWORD=vigilant_pass
DB_NAME=vigilant_db

# Session
SESSION_MAX_AGE=86400

# Google OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# SMTP (optional for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=alerts@vigilant.app

# Watcher
WATCHER_POLL_INTERVAL=60
WATCHER_ALERT_DAYS=3
